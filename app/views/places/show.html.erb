<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>

<div class="row">

  <% for entry in @entries %>

    <div class="col-md-4 mb-3">

      <div class="card h-100">

        <% if entry.image.attached? %>
          <%= image_tag entry.image, class: "card-img-top" %>
        <% end %>

        <div class="card-body">

          <h3><%= entry["title"] %></h3>

          <h5><%= entry["occurred_on"] %></h5>

          <p><%= entry["description"] %></p>

        </div>

      </div>

    </div>

  <% end %>

</div>

<% if @current_user %>

  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">
      New Entry
    </a>
  </p>

<% end %>

<p>
  <a href="/places" class="btn btn-secondary">
    Back to All Places
  </a>
</p>

